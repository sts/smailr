#!/usr/bin/env ruby

require 'smailr/version'

if ARGV == ['version'] || ARGV.include?('--version')
  puts "smailr #{Smailr::VERSION}"
  exit 0
end

require 'smailr'
require 'smailr/cli'
require 'smailr/setup'

begin
  Smailr.initialize!
rescue Smailr::ConfigurationError => e
  warn "ERROR: #{e.message}"
  exit 1
end

Smailr::Cli.new.run
